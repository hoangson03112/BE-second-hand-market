# Application
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/your-database

# Redis Configuration (Choose one method)

# Method 1: Upstash REST API (Recommended for Production)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Method 2: Traditional Redis (Local/Docker)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000,https://fe-second-hand-market-next-js.vercel.app
CORS_CREDENTIALS=true

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (Using Brevo/Sendinblue)
BREVO_API_KEY=your-brevo-api-key
MAIL_FROM_EMAIL=no-reply@your-domain.com
MAIL_FROM_NAME=Eco Market
# Optional: Use Brevo template instead of inline HTML
# BREVO_TEMPLATE_ID=1

# Email (Legacy Gmail - Deprecated)
# USERNAME_GMAIL=your-email@gmail.com
# PASSWORD_GMAIL=your-gmail-app-password

# Payment
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# AI (Gemini)
GOOGLE_AI_KEY=your-google-ai-key
# Recommended: gemini-embedding-001 (legacy: text-embedding-004)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Keep in sync with MongoDB vector index dimensions
EMBEDDING_DIMENSION=768
GEMINI_CHAT_MODEL=gemini-1.5-flash
PRODUCT_VECTOR_INDEX=vector_index

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
ENABLE_HELMET=true
ENABLE_COMPRESSION=true
